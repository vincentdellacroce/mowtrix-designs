# ── Mowtrix Designs · environment ──────────────────────────────
# All optional. The site works fully without these (audit uses a
# deterministic engine + localStorage; forms show success states).
# Copy to .env.local and fill in to go live.

# Booking link (Cal.com / Calendly) used by the "Book a call" CTAs
NEXT_PUBLIC_BOOKING_URL=https://cal.com/mowtrix

# Contact form endpoint (e.g. Formspree, a Google Apps Script, an API route)
NEXT_PUBLIC_CONTACT_ENDPOINT=

# ── Audit "database" via a Google Form ─────────────────────────
# Create a Google Form with short-answer questions, then grab the
# formResponse URL and the entry.XXXX field IDs (View source on the form).
# This logs every audit run so repeat visitors are tracked server-side too.
NEXT_PUBLIC_AUDIT_FORM_URL=
NEXT_PUBLIC_AUDIT_FIELD_BUSINESS=entry.000000001
NEXT_PUBLIC_AUDIT_FIELD_NICHE=entry.000000002
NEXT_PUBLIC_AUDIT_FIELD_SCORE=entry.000000003
NEXT_PUBLIC_AUDIT_FIELD_VISIT=entry.000000004
